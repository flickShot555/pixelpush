# Required to run PixelPush locally / in Vercel

# Neon Postgres connection string (Prisma)
# Use a non-pooled (direct) connection for Prisma migrations when possible.
DIRECT_URL=
DATABASE_URL=

# NextAuth secret used for JWT signing + middleware token verification
AUTH_SECRET=

# GitHub OAuth (required for GitHub connect + contribution syncing)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Recommended (esp. in production). On Vercel, set this to your deployed domain.
NEXTAUTH_URL=http://localhost:3000
